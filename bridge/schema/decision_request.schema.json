{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modhoi4.local/bridge/schema/decision_request.schema.json",
  "title": "DecisionRequest",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "turn_id",
    "country_tag",
    "timestamp_utc",
    "allowed_actions",
    "context"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Unique request identifier generated by the game runtime."
    },
    "turn_id": {
      "type": "integer",
      "minimum": 0,
      "description": "Deterministic game turn counter."
    },
    "country_tag": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Three-letter country tag (e.g. GER, ENG)."
    },
    "timestamp_utc": {
      "type": "string",
      "format": "date-time"
    },
    "allowed_actions": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "propose",
          "threaten",
          "request_help",
          "counter_offer",
          "delay",
          "accept",
          "reject",
          "secret_offer",
          "public_statement"
        ]
      },
      "description": "Whitelisted actions provided by the host for this decision window."
    },
    "context": {
      "type": "object",
      "additionalProperties": true,
      "description": "Opaque game state projection used by the bridge model."
    }
  }
}
