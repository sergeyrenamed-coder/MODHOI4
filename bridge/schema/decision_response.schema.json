{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://modhoi4.local/bridge/schema/decision_response.schema.json",
  "title": "DecisionResponse",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "request_id",
    "action",
    "confidence",
    "reason_codes",
    "cooldown_hint_days",
    "requires_human_visible_event"
  ],
  "properties": {
    "request_id": {
      "type": "string",
      "minLength": 1,
      "description": "Must match the request_id from the input request."
    },
    "action": {
      "type": "string",
      "enum": [
        "propose",
        "threaten",
        "request_help",
        "counter_offer",
        "delay",
        "accept",
        "reject",
        "secret_offer",
        "public_statement"
      ]
    },
    "target_country_tag": {
      "type": "string",
      "pattern": "^[A-Z]{3}$",
      "description": "Optional target for bilateral actions."
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "maxLength": 1000,
      "description": "Natural language payload shown to diplomacy systems/logs."
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1,
      "description": "Model confidence score in [0, 1]."
    },
    "reason_codes": {
      "type": "array",
      "minItems": 1,
      "maxItems": 16,
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9_]{2,64}$"
      },
      "description": "Machine-readable rationale tags used for audits and analytics."
    },
    "cooldown_hint_days": {
      "type": "integer",
      "minimum": 0,
      "maximum": 365,
      "description": "Suggested cooldown before sending another diplomatic action to the same target."
    },
    "requires_human_visible_event": {
      "type": "boolean",
      "description": "If true, host must emit a visible event/log entry before applying action."
    },
    "metadata": {
      "type": "object",
      "additionalProperties": {
        "type": [
          "string",
          "number",
          "integer",
          "boolean",
          "null"
        ]
      }
    }
  }
}
